<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ShopCart</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand fw-bold" href="/">🛒 ShopCart</a>
      <div class="ms-auto">
        <% if (typeof user !== 'undefined') { %>
          <a href="/cart" class="btn btn-light me-2">🛍️ Cart</a>
          <a href="/orders/history" class="btn btn-light me-2">📜 Orders</a>
          <a href="/logout" class="btn btn-outline-light">Logout</a>
        <% } else { %>
          <a href="/login" class="btn btn-light me-2">Login</a>
          <a href="/signup" class="btn btn-outline-light">Signup</a>
        <% } %>
      </div>
    </div>
  </nav>