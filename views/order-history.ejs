<%- include('partials/header') %>
<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>🛍️ Order History</h2>
    <a href="/dashboard" class="btn btn-outline-primary">🏠 Go to Dashboard</a>
  </div>

  <% if (orders.length === 0) { %>
    <div class="text-center py-5">
      <h4>No orders yet</h4>
      <a href="/products/catalogue" class="btn btn-primary">Start Shopping</a>
    </div>
  <% } else { %>
    <% orders.forEach(order => { %>
      <div class="card mb-4 shadow-sm">
        <div class="card-header bg-light">
          <div class="d-flex justify-content-between">
            <strong>Order ID: <%= order.razorpay_order_id || 'ORD-' + order.id %></strong>
            <span class="badge bg-success"><%= order.status.toUpperCase() %></span>
          </div>
          <small class="text-muted">Placed on: <%= new Date(order.created_at).toLocaleString() %></small>
        </div>
        <div class="card-body">
          <p><strong>Items:</strong> <%= order.items %></p>
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="text-success">Total: ₹<%= parseFloat(order.total_amount).toFixed(2) %></h5>
            <span class="text-muted">Payment ID: <%= order.razorpay_payment_id || 'N/A' %></span>

            <!-- New View Details Button -->
            <a href="/orders/details/<%= order.id %>" class="btn btn-primary btn-sm">
            View Details
            </a>  

          </div>
        </div>
      </div>
    <% }); %>
  <% } %>
</div>
<%- include('partials/footer') %>