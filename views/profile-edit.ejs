<%- include('partials/header') %>

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-8">
      <div class="card shadow-lg">
        <div class="card-header bg-primary text-white">
          <h4 class="mb-0">👤 Account Information</h4>
        </div>
        <div class="card-body">

          <% if (success) { %>
            <div class="alert alert-success"><%= success %></div>
          <% } %>
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>

          <form action="/profile/edit" method="POST">
            
            <!-- Personal Info -->
            <h5 class="mb-3">Personal Information</h5>
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Full Name</label>
                <input type="text" name="name" class="form-control" value="<%= user.name || '' %>" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Email Address</label>
                <!-- Email field made non-editable -->
                <input type="email" 
                       name="email" 
                       class="form-control bg-light" 
                       value="<%= user.email %>" 
                       readonly 
                       required> 
              </div>
            </div>

            <hr class="my-4">

            <!-- Shipping Address -->
            <h5 class="mb-3">📍 Shipping Address</h5>
            
            <div class="mb-3">
              <label class="form-label fw-bold">Address Line</label>
              <textarea name="shipping_address" class="form-control" rows="2"><%= user.shipping_address || '' %></textarea>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">City</label>
                <input type="text" name="shipping_city" class="form-control" value="<%= user.shipping_city || '' %>">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">State</label>
                <input type="text" name="shipping_state" class="form-control" value="<%= user.shipping_state || '' %>">
              </div>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
    <label class="form-label fw-bold">ZIP / Postal Code</label>
    <input 
      type="number" 
      name="shipping_zip" 
      class="form-control" 
      value="<%= user.shipping_zip || '' %>" 
      min="1" 
      step="1"
      placeholder="e.g. 110001"
      title="ZIP Code must be a positive number greater than 0"
      required>
    <small class="text-muted">Must be a positive integer (minimum 1)</small>
  </div>
              <div class="col-md-6 mb-3">
                <label class="form-label">Country</label>
                <input type="text" name="shipping_country" class="form-control" value="<%= user.shipping_country || 'India' %>">
              </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100 mt-4">
              Update Account & Shipping Information
            </button>
          </form>

          <hr class="my-5">

          <!-- Change Password -->
          <h5 class="mt-4">🔒 Change Password</h5>
          <form action="/profile/password" method="POST">
            <div class="mb-3">
              <label class="form-label">New Password</label>
              <input type="password" name="newPassword" class="form-control" minlength="6" required>
            </div>
            <div class="mb-4">
              <label class="form-label">Confirm New Password</label>
              <input type="password" name="confirmPassword" class="form-control" minlength="6" required>
            </div>

            <button type="submit" class="btn btn-outline-danger w-100">
              Update Password
            </button>
          </form>
        </div>
      </div>

      <div class="text-center mt-4">
        <a href="/dashboard" class="btn btn-outline-primary">
          ← Back to Dashboard
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>