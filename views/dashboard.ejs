<%- include('partials/header') %>

<div class="container mt-5">
  <div class="row">
    <!-- Welcome Header -->
    <div class="col-12 mb-4">
      <div class="card shadow border-0 bg-primary text-white">
        <div class="card-body p-5">
          <h1 class="display-5 fw-bold">Welcome back, <%= user.name || user.email.split('@')[0] %>! 👋</h1>
          <p class="lead">Manage your account, orders, and shopping from here.</p>
        </div>
      </div>
    </div>

    <!-- Stats Cards -->
    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <h2 class="text-primary mb-0"><%= totalOrders || 0 %></h2>
          <p class="text-muted">Total Orders</p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <h2 class="text-success mb-0">₹<%= totalSpent ? totalSpent.toFixed(2) : '0.00' %></h2>
          <p class="text-muted">Total Spent</p>
        </div>
      </div>
    </div>

    <div class="col-md-4 mb-4">
      <div class="card h-100 shadow-sm">
        <div class="card-body text-center">
          <h2 class="text-info mb-0"><%= recentOrders ? recentOrders.length : 0 %></h2>
          <p class="text-muted">Recent Orders</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Recent Orders -->
  <div class="card shadow-sm mt-4">
    <div class="card-header bg-light">
      <h5>Recent Orders</h5>
    </div>
    <div class="card-body">
      <% if (recentOrders && recentOrders.length > 0) { %>
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>Order ID</th>
                <th>Date</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Action</th>
              </tr>
            </thead>
            <tbody>
              <% recentOrders.forEach(order => { %>
                <tr>
                  <td>#<%= order.id %></td>
                  <td><%= new Date(order.created_at).toLocaleDateString() %></td>
                  <td>₹<%= parseFloat(order.total_amount).toFixed(2) %></td>
                  <td><span class="badge bg-success"><%= order.status %></span></td>
                  <td>
                    <a href="/orders/details/<%= order.id %>" class="btn btn-sm btn-primary">View</a>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <p class="text-muted text-center py-4">You haven't placed any orders yet.</p>
      <% } %>
    </div>
    <div class="card-footer">
      <a href="/orders/history" class="btn btn-outline-primary">View All Orders →</a>
    </div>
  </div>

  <!-- Quick Actions -->
  <div class="row mt-5">
    <div class="col-md-6">
      <a href="/products/catalogue" class="btn btn-primary btn-lg w-100 py-4 shadow">
        🛒 Continue Shopping
      </a>
    </div>
    <div class="col-md-6">
      <a href="/cart" class="btn btn-outline-primary btn-lg w-100 py-4 shadow">
        🛍️ View Your Cart
      </a>
    </div>
  </div>
</div>

<%- include('partials/footer') %>